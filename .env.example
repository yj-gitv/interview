# === 必填 ===
INTERVIEW_OPENAI_API_KEY=sk-your-key-here
INTERVIEW_OPENAI_BASE_URL=https://api.openai.com/v1

# === 可选：LLM 模型 ===
# INTERVIEW_OPENAI_MODEL_FAST=gpt-4o-mini
# INTERVIEW_OPENAI_MODEL_STRONG=gpt-4o

# === 可选：语音识别（需音频输入设备） ===
# INTERVIEW_WHISPER_MODEL=base
# INTERVIEW_AUDIO_DEVICE_NAME=BlackHole 2ch

# === 可选：说话人分离 ===
# INTERVIEW_DIARIZATION_ENABLED=true
# INTERVIEW_DIARIZATION_METHOD=energy

# === 可选：推送通知 ===
# INTERVIEW_DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
# INTERVIEW_FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# === 可选：数据清理 ===
# INTERVIEW_AUTO_CLEANUP_ENABLED=false
# INTERVIEW_AUTO_CLEANUP_DAYS=90

# === 可选：数据库加密 ===
# INTERVIEW_DB_ENCRYPTION_KEY=your-secret-key

# === Docker 端口（默认 3000）===
# APP_PORT=3000
